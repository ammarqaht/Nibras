# ============================================================
# Nibras — environment variables
# ------------------------------------------------------------
# The site RUNS WITHOUT these set: registrations fall back to a
# local JSON counter (.data/membership-counter.json) and the
# membership number is generated locally. See lib/membership.ts.
#
# TODO (data layer): to enable real persistence + DB-backed
# incrementing membership numbers, set DATABASE_URL / DIRECT_URL
# to a PostgreSQL instance (same convention as the Attendance site),
# then run:  npm run db:push
# ============================================================
# DATABASE_URL="postgresql://user:pass@host:5432/nibras?schema=public"
# DIRECT_URL="postgresql://user:pass@host:5432/nibras?schema=public"
