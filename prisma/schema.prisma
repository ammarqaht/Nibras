generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Registration {
  id                 Int      @id @default(autoincrement())
  membershipNo       Int      @unique
  studentName        String
  nationalId         String
  guardianPhone      String
  studentPhone       String?
  stage              String
  grade              String
  neighborhood       String
  locationLat        Float?
  locationLng        Float?
  mapLink            String?
  hasCondition       Boolean  @default(false)
  conditionNote      String?
  createdAt          DateTime @default(now())
  
  // Custom additions for dashboard
  paymentStatus      String   @default("unpaid")
  groupId            Int?
  registrationStatus String   @default("pending")
  paymentType        String   @default("later") // 'now' | 'later'
  paymentReceipt     String?                    // Base64 string of receipt image

  @@index([nationalId])
}

model Supervisor {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("supervisor") // 'admin' | 'supervisor' | 'finance'
  groupIds     String   @default("")           // comma-separated group IDs (e.g. "1,2")
  departments  String   @default("")           // comma-separated department keys (e.g. "cultural,families")
  createdAt    DateTime @default(now())
}

model Group {
  id        Int      @id @default(autoincrement())
  name      String
  stage     String
  createdAt DateTime @default(now())
}

model Attendance {
  id             Int      @id @default(autoincrement())
  registrationId Int
  date           String   // Format 'YYYY-MM-DD'
  status         String   // 'present' | 'absent' | 'late'
  recordedBy     String?
  createdAt      DateTime @default(now())
}

model Point {
  id             Int      @id @default(autoincrement())
  registrationId Int
  delta          Int      // +points or -points
  reason         String
  category       String   // 'behavior' | 'participation' | 'activity' | 'other'
  recordedBy     String?
  createdAt      DateTime @default(now())
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  body      String
  audience  String   // 'students' | 'guardians' | 'all'
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String // JSON string
}

model Invoice {
  id             Int       @id @default(autoincrement())
  invoiceNo      Int       @unique
  title          String
  vendor         String?
  invoiceDate    String?   // free-text date as printed on the invoice
  category       String?   // 'food' | 'supplies' | 'prizes' | 'transport' | 'other'
  department     String    // department key the invoice is filed under
  supervisorId   Int       // who entered it (from the session)
  supervisorName String
  groupId        Int?      // optional linked group/activity
  items          String    @default("[]") // JSON: [{ name, qty, price }]
  subtotal       Float?
  tax            Float?
  total          Float
  currency       String    @default("SAR")
  imageData      String?   // base64 data URL of the photographed invoice
  entryMode      String    @default("manual") // 'photo' | 'manual'
  aiExtracted    Boolean   @default(false)
  aiConfidence   Float?
  status         String    @default("pending") // 'pending' | 'approved' | 'rejected' | 'on_hold'
  settlement     String    @default("unsettled") // 'unsettled' | 'handed_over'
  reviewedBy     String?   // finance reviewer name
  reviewNote     String?   // rejection / hold reason
  settledAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([department])
  @@index([supervisorId])
  @@index([status])
}
